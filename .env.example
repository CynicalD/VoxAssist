# ── AI mode ─────────────────────────────────────────────────────────────
# "true" = always mocks (boots keyless); "false" = real Atlas + Voyage + LLMs
USE_MOCK_AI=true
# When USE_MOCK_AI=false, fall back to mocks if real retriever/generator fail
AI_FALLBACK_TO_MOCK=true

# ── Synthesis LLMs ──────────────────────────────────────────────────────
# ask → Gemini (light/fast); plan → Claude Opus
GEMINI_API_KEY=
GEMINI_ASK_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
CLAUDE_PLAN_MODEL=claude-opus-4-8

# ── MongoDB Atlas (vector store) ────────────────────────────────────────
# Node driver SRV string; Vector Search enabled. Indexes: npm run atlas:setup
MONGODB_URI=
MONGODB_DB=voxassist

# ── Voyage (embeddings) ─────────────────────────────────────────────────
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
EMBEDDING_DIM=1024

# ── ElevenLabs TTS / STT ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_STT_MODEL=scribe_v2

# ── Auth ────────────────────────────────────────────────────────────────
# Leave BOTH Clerk keys EMPTY for demo fake-auth (type a username to sign in).
# Set both to switch to real Clerk. After flipping keys, delete .next and restart.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional Clerk URLs (defaults work for most apps)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Vault owner defaults to the Clerk username (aliases: omen-mali→momen, cynicald→rayan).
# Optional override when username ≠ vault owner: userId:owner pairs
# Example: CLERK_OWNER_MAP=user_abc:momen,user_def:rayan
CLERK_OWNER_MAP=

# ── Guardrails ──────────────────────────────────────────────────────────
# Rate limit for live LLM calls (requests per minute per user); 0 disables
LLM_RATE_LIMIT_PER_MINUTE=30
# HTTP /api/ingest (file upload). Must be "true" for the in-app upload feature.
ALLOW_HTTP_INGEST=true
# Per-owner caps on /api/upload (guard Atlas M0 disk)
UPLOAD_MAX_CHUNKS_PER_USER=500
UPLOAD_MAX_DOCS_PER_USER=50
